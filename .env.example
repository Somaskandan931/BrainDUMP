# Copy this file to `.env` in the ai_os/ root and fill in real values.
# .env is (and should stay) git-ignored — never commit real secrets.

# --- Todoist (Milestone 6) ---------------------------------------------
# Personal API token: Todoist -> Settings -> Integrations -> Developer.
TODOIST_API_TOKEN=

# --- Google Calendar (Milestone 6) --------------------------------------
# No token goes here — Google uses an OAuth client secret file instead.
# Download one from Google Cloud Console (APIs & Services -> Credentials
# -> Create Credentials -> OAuth client ID -> Desktop app), save it as
# credentials.json in the ai_os/ root (next to this file). The first API
# call opens a browser for one-time consent and writes token.json, which
# is reused (and refreshed) on every run after that.
#
# Which calendar to read/write. "primary" is the account's main calendar
# — change only if you keep Brain Dump events on a separate calendar.
GOOGLE_CALENDAR_ID=primary
